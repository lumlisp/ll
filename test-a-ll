#!/bin/bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
EXAMPLES="$ROOT/examples"
PASS=0
FAIL=0

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }

step() {
  local msg="$1"
  shift
  printf '  %-40s ... ' "$msg"
  if "$@" > /dev/null 2>&1; then
    green "PASS"
    PASS=$((PASS + 1))
  else
    red "FAIL"
    FAIL=$((FAIL + 1))
  fi
}

check_file() {
  local label="$1" file="$2"
  shift 2
  local expected="$EXAMPLES/$(basename "$file" .ll).expected"
  if [ ! -f "$expected" ]; then
    printf '  %-40s ... SKIP (no .expected file)\n' "$label"
    return
  fi
  printf '  %-40s ... ' "$label"
  local got
  got="$("$@" 2>&1 || true)"
  local want
  want="$(cat "$expected")"
  if [ "$got" = "$want" ]; then
    green "PASS"
    PASS=$((PASS + 1))
  else
    red "FAIL"
    echo "--- expected ($expected) ---" >&2
    echo "$want" >&2
    echo "--- got ---" >&2
    echo "$got" >&2
    FAIL=$((FAIL + 1))
  fi
}

echo "=== test-a-ll: Lum Lisp Test Runner ==="
echo ""

echo "Build"
step "make build" make -C "$ROOT" build
LL="$ROOT/ll"

echo ""
echo "Unit tests"
step "make test" make -C "$ROOT" test

echo ""
echo "Examples"
check_file "hello.ll"     "$ROOT/examples/hello.ll"     "$LL" "$ROOT/examples/hello.ll"
check_file "fib.ll"       "$ROOT/examples/fib.ll"       "$LL" "$ROOT/examples/fib.ll"
check_file "fizzbuzz.ll"  "$ROOT/examples/fizzbuzz.ll"  "$LL" "$ROOT/examples/fizzbuzz.ll"
check_file "php-interop.ll" "$ROOT/examples/php-interop.ll" "$LL" "$ROOT/examples/php-interop.ll"
check_file "async.ll"     "$ROOT/examples/async.ll"     "$LL" "$ROOT/examples/async.ll"
check_file "oop.ll"       "$ROOT/examples/oop.ll"       "$LL" "$ROOT/examples/oop.ll"

echo ""
echo "=== Results: $PASS passed, $FAIL failed ==="
[ "$FAIL" -eq 0 ] || exit 1
